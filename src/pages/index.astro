---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={"Pumpkin - Blazingly Fast Minecraft Server"}
  description={"Pumpkin: The fastest, most efficient Minecraft server software. Written in Rust."}
  ogTitle={"Pumpkin - Blazingly Fast Minecraft Server"}
  ogDescription={"1000x faster startup. 18x less memory. Built with Rust for maximum performance."}
  ogUrl={"https://pumpkinmc.org/"}
  pageStyle={"/styles/home.css"}
  includeAdsense
>
<main>
      <section class="hero">
        <div class="hero-left">
          <div class="hero-badge">NEW</div>
          <h1>
            The world's fastest
            <span class="highlight">Minecraft</span>
            server.
          </h1>
          <p>
            1000x faster startup than vanilla. 18x less memory. Built with Rust
            for maximum performance.
          </p>
          <div class="hero-buttons">
            <a href="/download/" class="btn btn-primary">
              Download Free
              <i class="fa-solid fa-arrow-down"></i>
            </a>
            <a href="/developers/" class="btn btn-secondary">
              Build Plugins
            </a>
          </div>
        </div>
        <div class="hero-right">
          <div class="hero-card">
            <img src="/assets/icon.svg" alt="Pumpkin Logo" class="hero-logo" />
            <div class="hero-stats">
              <div class="hero-stat">
                <span class="num">~5ms</span>
                <span class="label">startup</span>
              </div>
              <div class="hero-stat">
                <span class="num">~100MB</span>
                <span class="label">memory</span>
              </div>
              <div class="hero-stat">
                <span class="num">~0.1%</span>
                <span class="label">CPU idle</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="features">
        <h2 class="section-title">
          Why developers <span class="highlight">love</span> Pumpkin
        </h2>

        <div class="features-grid">
          <div class="feature-card color-orange">
            <div class="feature-number">01</div>
            <h3>Instant Startup</h3>
            <p>
              Server ready in ~5 milliseconds. Not 15 seconds. That's 1000x
              faster than vanilla.
            </p>
          </div>

          <div class="feature-card color-blue">
            <div class="feature-number">02</div>
            <h3>Tiny Memory</h3>
            <p>
              Runs on ~100MB RAM while vanilla needs 1.8GB. Perfect for cheap
              VPS hosting.
            </p>
          </div>

          <div class="feature-card color-green">
            <div class="feature-number">03</div>
            <h3>Multi-threaded</h3>
            <p>
              Actually uses all your CPU cores. Not just for chunks—for
              everything.
            </p>
          </div>

          <div class="feature-card color-purple">
            <div class="feature-number">04</div>
            <h3>Cross-Play</h3>
            <p>
              Java and Bedrock players together. Built-in, no plugins required.
            </p>
          </div>

          <div class="feature-card color-pink">
            <div class="feature-number">05</div>
            <h3>No Java</h3>
            <p>
              Single executable file. Download, double-click, done. Zero setup.
            </p>
          </div>

          <div class="feature-card color-yellow">
            <div class="feature-number">06</div>
            <h3>Open Source</h3>
            <p>
              GPL licensed. Read the code, contribute, fork it. Full
              transparency.
            </p>
          </div>
        </div>
      </section>

      <section class="comparison">
        <h2 class="section-title">
          See the <span class="highlight">difference</span>
        </h2>

        <div class="comparison-grid">
          <div class="comp-card">
            <h3><i class="fa-solid fa-stopwatch"></i> Startup Time</h3>
            <div class="comp-bars">
              <div class="comp-item winner">
                <span class="comp-name">Pumpkin</span>
                <div
                  class="comp-bar"
                  style="--bar-width: 0.0333%; --bar-duration: 0.005s; --bar-min-width: 12px"
                ></div>
                <span class="comp-value">~5ms</span>
              </div>
              <div class="comp-item">
                <span class="comp-name">Paper</span>
                <div
                  class="comp-bar"
                  style="--bar-width: 66.6667%; --bar-duration: 10s"
                ></div>
                <span class="comp-value">~10s</span>
              </div>
              <div class="comp-item">
                <span class="comp-name">Vanilla</span>
                <div
                  class="comp-bar"
                  style="--bar-width: 100%; --bar-duration: 15s"
                ></div>
                <span class="comp-value">~15s</span>
              </div>
            </div>
          </div>

          <div class="comp-card">
            <h3><i class="fa-solid fa-memory"></i> RAM Usage</h3>
            <div class="comp-bars no-animate">
              <div class="comp-item winner">
                <span class="comp-name">Pumpkin</span>
                <div class="comp-bar" style="--bar-width: 5.5556%"></div>
                <span class="comp-value">~100MB</span>
              </div>
              <div class="comp-item">
                <span class="comp-name">Paper</span>
                <div class="comp-bar" style="--bar-width: 77.7778%"></div>
                <span class="comp-value">~1.4GB</span>
              </div>
              <div class="comp-item">
                <span class="comp-name">Vanilla</span>
                <div class="comp-bar" style="--bar-width: 100%"></div>
                <span class="comp-value">~1.8GB</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="table-section">
        <h2 class="section-title">
          Feature <span class="highlight">Checklist</span>
        </h2>

        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th class="col-pumpkin">Pumpkin</th>
              <th>Vanilla</th>
              <th>Spigot/Paper</th>
              <th>Folia</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <strong>Fast Startup Times</strong>
                <span class="feature-desc"
                  >Get your server online in under a second.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <i class="fa-solid fa-check check-icon"></i>
              </td>
              <td data-label="Vanilla">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-xmark cross-icon"></i>
                  <span class="tooltip"
                    >Slower startup due to less optimization.</span
                  >
                </span>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-xmark cross-icon"></i>
                  <span class="tooltip"
                    >Can have slower startup due to complex
                    initialization.</span
                  >
                </span>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Optimized CPU Utilization</strong>
                <span class="feature-desc"
                  >Maximize performance while minimizing resource strain.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <i class="fa-solid fa-check check-icon"></i>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Superior Memory Optimization</strong>
                <span class="feature-desc"
                  >Run larger servers with less memory.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <i class="fa-solid fa-check check-icon"></i>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Multi-threading Support</strong>
                <span class="feature-desc"
                  >Leverage modern CPUs for unparalleled scalability.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-check check-icon"></i>
                  <span class="tooltip"
                    >Comprehensive multi-threading for core game logic and
                    tasks.</span
                  >
                </span>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip">Only ticks.</span>
                </span>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Bukkit/Paper Plugin Support</strong>
                <span class="feature-desc"
                  >Early development with growing support.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip"
                    >Pumpkin uses its own API, but compatibility is possible via
                    <a href="https://github.com/Pumpkin-MC/PatchBukkit"
                      >PatchBukkit</a
                    >.</span
                  >
                </span>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-check check-icon"></i>
                  <span class="tooltip"
                    >Full plugin support via Bukkit/Paper API.</span
                  >
                </span>
              </td>
              <td data-label="Folia">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip"
                    >Compatibility varies; some plugins may require updates due
                    to multi-threading.</span
                  >
                </span>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Cross-Edition Compatibility</strong>
                <span class="feature-desc"
                  >Allow players on different game editions (Java/Bedrock) to
                  join.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-check check-icon"></i>
                  <span class="tooltip"
                    >Built-in support for both Java & Bedrock Editions.</span
                  >
                </span>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip"
                    >Achievable via external plugins (e.g., GeyserMC).</span
                  >
                </span>
              </td>
              <td data-label="Folia">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip"
                    >Achievable via external plugins, but setup might be more
                    complex due to multi-threading.</span
                  >
                </span>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Comprehensive Developer API</strong>
                <span class="feature-desc"
                  >Create custom features and integrations easily.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-check check-icon"></i>
                  <span class="tooltip"
                    >Rich and easy-to-use API for extensive customization.</span
                  >
                </span>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Extensive Configuration Options</strong>
                <span class="feature-desc"
                  >Tailor server behavior with granular control.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-check check-icon"></i>
                  <span class="tooltip"
                    >Provides a large configuration, that will cover every
                    need.</span
                  >
                </span>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Open-Source</strong>
                <span class="feature-desc"
                  >Benefit from community contributions & transparency.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <i class="fa-solid fa-check check-icon"></i>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip">Only Open-Source patches.</span>
                </span>
              </td>
              <td data-label="Folia">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-triangle-exclamation warning-icon"></i>
                  <span class="tooltip">Only Open-Source patches.</span>
                </span>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Multiple World/Chunk Formats</strong>
                <span class="feature-desc"
                  >Support for more efficient world data storage and
                  loading.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <i class="fa-solid fa-check check-icon"></i>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <span class="has-tooltip"
                  ><i class="fa-solid fa-xmark cross-icon"></i>
                  <span class="tooltip">Primarily uses Anvil format.</span>
                </span>
              </td>
            </tr>
            <tr>
              <td>
                <strong>Click & Play</strong>
                <span class="feature-desc"
                  >Self-contained executable for instant launch, no complex
                  setup or Java installation required.</span
                >
              </td>
              <td class="col-pumpkin" data-label="Pumpkin">
                <i class="fa-solid fa-check check-icon"></i>
              </td>
              <td data-label="Vanilla">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Spigot/Paper">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
              <td data-label="Folia">
                <i class="fa-solid fa-xmark cross-icon"></i>
              </td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="cta">
        <div class="cta-card">
          <h2>Ready to try?</h2>
          <p>
            Download Pumpkin and experience the fastest Minecraft server ever
            built.
          </p>
          <div class="cta-buttons">
            <a href="/download/" class="btn btn-primary btn-large">
              Download Now <i class="fa-solid fa-arrow-right"></i>
            </a>
            <a
              href="https://github.com/Pumpkin-MC"
              class="btn btn-secondary btn-large"
            >
              <i class="fa-brands fa-github"></i> Star on GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

  <script>
    import "../scripts/home";
  </script>
</BaseLayout>
