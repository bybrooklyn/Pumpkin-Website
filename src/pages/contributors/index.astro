---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title={"Contributors - Pumpkin"}
  description={"Meet the amazing people who contribute to Pumpkin, the fastest Minecraft server."}
  ogTitle={"Contributors - Pumpkin"}
  ogDescription={"Meet the amazing people who contribute to Pumpkin, the fastest Minecraft server."}
  ogUrl={"https://pumpkinmc.org/contributors/"}
  pageStyle={"/styles/contributors.css"}
>
<main>
    <section class="contributors-hero">
      <h1 class="section-title">
        Meet our <span class="highlight">Contributors</span>
      </h1>
      <p>
        Pumpkin is built by an amazing community of open source contributors.
      </p>
      <div class="contributor-stats">
        <div class="stat-box">
          <span class="stat-num" id="total-contributors">-</span>
          <span class="stat-label">Contributors</span>
        </div>
        <div class="stat-box">
          <span class="stat-num" id="total-commits">-</span>
          <span class="stat-label">Commits</span>
        </div>
      </div>
    </section>

    <section class="sponsors-section">
      <h2 class="section-subtitle"><i class="fa-solid fa-heart"></i> Sponsors</h2>
      <p class="sponsors-desc">These amazing people help fund Pumpkin's development.</p>

      <div class="sponsor-tabs">
        <button class="sponsor-tab active" data-tab="current">Current</button>
        <button class="sponsor-tab" data-tab="past">Past / One-time</button>
      </div>

      <div id="sponsors-current-wrapper">

        <div class="tier-group tier-titanium">
          <h3 class="tier-header"><i class="fa-solid fa-shield-halved"></i> Titanium Sponsors</h3>
          <div class="sponsors-grid tier-grid-titanium">
            <a href="https://github.com/Lysander05" class="sponsor-card" target="_blank">
              <img src="https://avatars.githubusercontent.com/u/56302470?v=4" alt="Lysander" />
              <span>Lysander</span>
            </a>
            <a href="https://github.com/starrider346" class="sponsor-card" target="_blank">
              <img src="https://avatars.githubusercontent.com/u/58882729?v=4" alt="Strider" />
              <span>Strider</span>
            </a>
            <a href="https://github.com/wynn-dev" class="sponsor-card" target="_blank">
              <img src="https://avatars.githubusercontent.com/u/66362261?v=4" alt="wynn" />
              <span>wynn</span>
            </a>
          </div>
        </div>

        <div class="tier-group tier-platinum">
          <h3 class="tier-header"><i class="fa-solid fa-shield-halved"></i> Platinum Sponsors</h3>
          <div class="sponsors-grid tier-grid-platinum">
            <a href="https://github.com/Oldprotocol" class="sponsor-card" target="_blank">
              <img src="https://avatars.githubusercontent.com/u/265181542?v=4" alt="Oldprotocol" />
              <span>Oldprotocol</span>
            </a>
          </div>
        </div>

        <div class="tier-group tier-silver">
          <h3 class="tier-header"><i class="fa-solid fa-medal"></i> Silver Sponsors</h3>
          <div class="sponsors-grid">
            <a href="https://github.com/lineality" class="sponsor-card" target="_blank"><span>Geoffrey Gordon
                Ashbrook</span></a>
            <a href="https://github.com/GodData001" class="sponsor-card" target="_blank"><span>GodData001</span></a>
            <a href="https://github.com/Pookachu" class="sponsor-card" target="_blank"><span>Pooka</span></a>
          </div>
        </div>

        <div class="tier-group tier-bronze">
          <h3 class="tier-header"><i class="fa-solid fa-user-group"></i> Bronze Sponsors</h3>
          <div class="sponsors-grid">
            <a href="https://github.com/clemensrh" class="sponsor-card" target="_blank"><span>Clemens</span></a>
            <a href="https://github.com/bybrooklyn" class="sponsor-card" target="_blank"><span>Brook</span></a>
            <a href="https://github.com/Grimwald-SMP" class="sponsor-card" target="_blank"><span>Grimwald SMP</span></a>
            <a href="https://github.com/ThatOneToast" class="sponsor-card" target="_blank"><span>White Bread</span></a>
            <a href="https://github.com/snarkyalyx" class="sponsor-card" target="_blank"><span>Alyx Buckmann</span></a>
            <a href="https://github.com/mtthidoteu" class="sponsor-card" target="_blank"><span>Matthieu B</span></a>
            <a href="https://github.com/GjorgjiML" class="sponsor-card" target="_blank"><span>Gjorgji
                Mladenovski</span></a>
            <a href="https://github.com/illyrius666" class="sponsor-card" target="_blank"><span>Illyrius</span></a>
            <a href="https://github.com/Schweeeeeeeeeeeeeeee" class="sponsor-card"
              target="_blank"><span>Schweeeeeeeeeeeeeeee</span></a>
            <a href="https://github.com/alexanderstdev" class="sponsor-card" target="_blank"><span>Alexander
                Andersen</span></a>

            <a href="https://github.com/sponsors/Pumpkin-MC" class="sponsor-card become-sponsor">
              <i class="fa-solid fa-plus"></i>
              <span>Become a Sponsor</span>
            </a>
          </div>
        </div>
      </div>

      <div id="sponsors-past" class="hidden">
        <div class="sponsors-grid">
          <a href="https://github.com/Rotstein007" class="sponsor-card" target="_blank"><span>Rotstein</span></a>
          <a href="https://github.com/bartwx" class="sponsor-card" target="_blank"><span>Bart Wiggers</span></a>
          <a href="https://github.com/RoosterBooster007" class="sponsor-card" target="_blank"><span>RB007
            </span></a>
          <a href="https://github.com/Vianpyro" class="sponsor-card" target="_blank"><span>Vianney Veremme
            </span></a>
          <a href="https://github.com/robke96" class="sponsor-card" target="_blank"><span>Robertas</span></a>
          <a href="https://github.com/ayubrawr" class="sponsor-card" target="_blank"><span>ayub</span></a>
          <a href="https://github.com/Byundai" class="sponsor-card" target="_blank"><span>Byundai</span></a>
          <a href="https://github.com/Siydge" class="sponsor-card" target="_blank"><span>Siydge</span></a>
          <a href="https://github.com/ItzCelyrian" class="sponsor-card" target="_blank"><span>ItzCelyrian</span></a>
          <a href="https://github.com/Wuemeli" class="sponsor-card" target="_blank"><span>Wuemeli</span></a>
          <a href="https://github.com/DylanClouden28" class="sponsor-card"
            target="_blank"><span>DylanClouden28</span></a>
          <a href="https://github.com/vyPal" class="sponsor-card" target="_blank"><span>vyPal</span></a>
          <a href="https://github.com/Unoqwy" class="sponsor-card" target="_blank"><span>Unoqwy</span></a>
          <a href="https://github.com/ForceGamer" class="sponsor-card" target="_blank"><span>Force</span></a>
          <a href="https://github.com/sweattypalms" class="sponsor-card" target="_blank"><span>Sweattypalms</span></a>

          <div class="sponsor-card private-sponsor"><i class="fa-solid fa-user-secret"></i><span>Private Sponsor</span>
          </div>
        </div>
      </div>
    </section>

    <section class="contributors-section">
      <h2 class="section-subtitle">
        <i class="fa-solid fa-code"></i> Contributors
      </h2>
      <div class="contributors-grid" id="contributors-grid">
        <div class="loading-state">
          <i class="fa-solid fa-spinner fa-spin"></i>
          <span>Loading contributors...</span>
        </div>
      </div>
      <button class="btn btn-secondary show-more-btn" id="show-more-btn" style="display: none">
        Show More <i class="fa-solid fa-chevron-down"></i>
      </button>
    </section>

    <section class="cta">
      <div class="cta-card">
        <h2>Want to contribute?</h2>
        <p>
          Join our community and help build the fastest Minecraft server ever.
        </p>
        <div class="cta-buttons">
          <a href="https://github.com/Pumpkin-MC/Pumpkin" class="btn btn-primary btn-large">
            <i class="fa-brands fa-github"></i> View on GitHub
          </a>
          <a href="https://discord.gg/pumpkinmc" class="btn btn-secondary btn-large">
            <i class="fa-brands fa-discord"></i> Join Discord
          </a>
        </div>
      </div>
    </section>
  </main>

  <script>
    import "../../scripts/contributors";
  </script>
</BaseLayout>
